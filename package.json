    "@types/node": "24.7.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  }
