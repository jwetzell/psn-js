	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@eslint/js": "10.0.1",
		"@types/node": "24.7.2",
		"globals": "17.7.0",
		"rimraf": "6.1.3",
		"tsdown": "0.22.7",
		"typescript": "7.0.2"
	}
